rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: This is a temporary, insecure rule for diagnostics.
    // It allows anyone to read or write to any document in your database.
    // We will replace this with secure rules once data loading is confirmed.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
