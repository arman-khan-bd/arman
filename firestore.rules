/**
 * Core Philosophy:
 * This ruleset enforces a "Public Read, Owner-Only Write" security model for most profile data.
 * All portfolio content is publicly visible, but modification is strictly limited to the authenticated
 * user who owns that profile. Specific collections like 'comments' and 'orders' have unique rules
 * to allow public creation while maintaining owner control.
 *
 * Key Security Decisions:
 * - Public Read Access: Most profile-related data is publicly readable.
 * - Strict Ownership for Writes: Write operations are gated by matching the user's UID against the
 *   `profileId` or a denormalized `ownerId`.
 * - Authorization Independence: The `ownerId` is denormalized (copied) onto subcollection documents
 *   to avoid slow and costly `get()` calls in security rules.
 * - Explicit Subcollection Rules: Each subcollection (`blogs`, `comments`, `projects`, etc.) has its
 *   own specific rule block, avoiding ambiguity from generic wildcards.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the profileId from the URL.
     * This is the primary check for ownership.
     */
    function isProfileOwner(profileId) {
      return isSignedIn() && request.auth.uid == profileId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents.
     * @path /profiles/{profileId}
     */
    match /profiles/{profileId} {
      allow read: if true;
      allow create, update, delete: if isProfileOwner(profileId);

      // --- Subcollection Rules ---

      // Projects, Skills, Experience, Education: Public read, owner write.
      match /projects/{projectId} {
        allow read: if true;
        allow create, update, delete: if isProfileOwner(profileId);
      }
      match /skills/{skillId} {
        allow read: if true;
        allow create, update, delete: if isProfileOwner(profileId);
      }
      match /workExperiences/{experienceId} {
        allow read: if true;
        allow create, update, delete: if isProfileOwner(profileId);
      }
      match /educations/{educationId} {
        allow read: if true;
        allow create, update, delete: if isProfileOwner(profileId);
      }
      
      /**
       * @description Rules for Blog posts and their nested Comments.
       */
      match /blogs/{blogId} {
        allow read: if true;
        allow create, update, delete: if isProfileOwner(profileId);

        /**
         * @description Special rules for Comments nested under a Blog.
         * Anyone can create and read comments. Only the profile owner can delete them.
         */
        match /comments/{commentId} {
          allow read: if true;
          // Allow public creation, but ensure it's for the correct blog and profile.
          allow create: if request.resource.data.profileId == profileId && request.resource.data.blogId == blogId;
          allow update: if false; // Comments are immutable
          allow delete: if isProfileOwner(profileId); // Owner can moderate
        }
      }

      /**
       * @description Special rules for Orders.
       * Anyone can create an order. Only the profile owner can read or delete them.
       */
      match /orders/{orderId} {
        allow read, delete: if isProfileOwner(profileId);
        allow create: if request.resource.data.profileId == profileId; // Allow public creation
        allow update: if false; // Orders are immutable
      }

      /**
       * @description Rules for Visitor logs.
       * Admin can read/delete. Creation is handled by the client after getting IP
       * data from a trusted API route.
       */
      match /visitors/{visitorId} {
        allow read, delete: if isProfileOwner(profileId);
        allow create: if request.resource.data.profileId == profileId;
        allow update: if false;
      }
    }

    /**
     * @description Rules for the admin roles collection. Access is highly restricted.
     * @path /admin_users/{userId}
     */
    match /admin_users/{userId} {
      allow read, write: if false; // Disallow all client access for security.
    }
  }
}

    