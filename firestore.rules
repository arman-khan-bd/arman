rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check ownership by reading the ownerId from the parent profile document.
    function isProfileOwner(profileId) {
      return request.auth != null && request.auth.uid == get(/databases/$(database)/documents/profiles/$(profileId)).data.ownerId;
    }
    
    // The main profile document. The document ID is the public github username.
    match /profiles/{profileId} {
      allow read: if true;
      // Allow writes only if the user is authenticated and their UID matches the ownerId in the document.
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
    
    // Admin-managed subcollections (blogs, projects, etc.)
    match /profiles/{profileId}/(skills|workExperiences|educations|projects|blogs)/{docId} {
      allow read: if true;
      // Allow writes only by the profile owner.
      allow write: if isProfileOwner(profileId);
    }
      
    // Comments: public can read/create, only owner can delete.
    match /profiles/{profileId}/blogs/{blogId}/comments/{commentId} {
      allow read, create: if true;
      allow delete: if isProfileOwner(profileId);
    }
      
    // Orders: public can create, only owner can manage.
    match /profiles/{profileId}/orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isProfileOwner(profileId);
    }
      
    // Visitors: public can create (via API), only owner can read/delete.
    match /profiles/{profileId}/visitors/{visitorId} {
       allow create: if true;
       allow read, delete: if isProfileOwner(profileId);
    }
      
    // Messages: public can create, only owner can manage.
    match /profiles/{profileId}/messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isProfileOwner(profileId);
    }
  }
}
