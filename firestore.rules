rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profiles are public, but only owner can write
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == profileId;
    }
    
    // Subcollections that are part of the public profile
    match /profiles/{profileId}/(skills|workExperiences|educations|projects|blogs)/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == profileId;
    }
      
    // Comments: Publicly readable/creatable, owner can delete
    match /profiles/{profileId}/blogs/{blogId}/comments/{commentId} {
      allow read, create: if true;
      allow delete: if request.auth != null && request.auth.uid == profileId;
    }
      
    // Orders: Creatable by public, only readable/writable by owner
    match /profiles/{profileId}/orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.uid == profileId;
    }
      
    // Visitors: Creatable by public (via API), only readable/deletable by owner
    match /profiles/{profileId}/visitors/{visitorId} {
       allow create: if true;
       allow read, delete: if request.auth != null && request.auth.uid == profileId;
    }
      
    // Messages: Creatable by public, only readable/deletable by owner
    match /profiles/{profileId}/messages/{messageId} {
      allow create: if true;
      allow read, delete: if request.auth != null && request.auth.uid == profileId;
    }
  }
}
